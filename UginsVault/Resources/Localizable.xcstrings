{
  "sourceLanguage": "en",
  "strings": {
    "#%@": {
      "comment": "A label displaying the collector number of a card. The argument is the card's collector number.",
      "isCommentAutoGenerated": true
    },
    "%@": {
      "comment": "A label showing the number of cards that were successfully saved during a reset operation. The argument is the number of cards that were successfully saved during a reset operation.",
      "isCommentAutoGenerated": true
    },
    "%@ cards": {
      "comment": "A label displaying the number of cards in the user's collection and the total value of those cards. The argument is the number of cards in the collection, and the second argument is the total value of those",
      "isCommentAutoGenerated": true
    },
    "%@ cards saved": {
      "comment": "A label displaying the number of cards that have been successfully saved to the user's catalogue. The argument is the number of cards that have been saved.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ cartas guardadas"
          }
        }
      }
    },
    "%@ stacks": {
      "comment": "A line displaying the number of stacks and cards in the user's vaults, along with the total value of all cards.",
      "isCommentAutoGenerated": true
    },
    "%@ unresolved": {
      "comment": "A note indicating that some cards in a recently imported list could not be added to the user's vault.",
      "isCommentAutoGenerated": true
    },
    "%@ · #%@": {
      "comment": "Displays the set code, collector number, and price of a card. The set code is displayed in uppercase, the collector number is displayed with a hash sign, and the price is displayed in USD.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ · #%2$@"
          }
        }
      }
    },
    "%@ · %@ · %@": {
      "comment": "A label describing the finish, condition, and language of a printed item. The first argument is the name of the finish. The second argument is the name of the condition. The third argument is the name of the language.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ · %2$@ · %3$@"
          }
        }
      }
    },
